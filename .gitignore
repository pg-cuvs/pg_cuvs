# Local-only sensitive context — never commit. Durable private copies live in
# the private repo ysys143/pg_cuvs_docs. CLAUDE.local.md = local Claude context.
CLAUDE.local.md
*.local*
node_modules/
__pycache__/
*.pyc
*.log
.DS_Store
.idea/
.vscode/
dist/
build/
*.egg-info/

# PGXS / CUDA build artifacts
*.o
