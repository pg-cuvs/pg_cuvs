*.bc
src/*.o

# Local unit-test binaries
/test-unit
/test-build-shm
/test-build-corpus
test/results/
test/regression.diffs
test/regression.out
# Anchored: an unanchored `results/` also swallowed bench/results/, so curated
# artifacts AND its README needed `git add -f` and were silently dropped from
# commits. bench/results is governed by bench/.gitignore (generated *.csv
# ignored, docs tracked); design/anbench/results by the design/anbench/ rule.
/results/
regression.diffs
regression.out

# Conda
miniforge3/
.conda/

# Benchmark output (kept in design/ folder)
design/bench_*.log

# Comparative ANN benchmark outputs (results/plots/logs; large, regenerable)
design/anbench/
.claude/scheduled_tasks.lock

# Local tool cache (project-path → UUID map; machine-specific)
cache/
